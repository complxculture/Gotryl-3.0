{
  "name": "@gotryl/cli",
  "version": "0.1.0",
  "description": "Gotryl CLI — cloud-based AI Playwright test runner",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "gotryl": "./dist/bin.js"
  },
  "keywords": ["gotryl", "playwright", "testing", "e2e", "ai", "cloud", "cli"],
  "homepage": "https://gotryl.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/complxculture/Gotryl-3.0.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin.js"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@gotryl/sdk": "workspace:*",
    "commander": "^12"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
