# Domain — used by Caddy for TLS and by the dashboard to reach the API
DOMAIN=yourdomain.com

# Database — generated by docker-compose.prod.yml, set a strong password
POSTGRES_PASSWORD=change-me-strong-password

# Redis — no password needed for single-VPS (Redis is not exposed externally)
# REDIS_URL is constructed internally: redis://redis:6379

# Cloudflare R2 — artifact storage (screenshots, videos, DOM snapshots)
# Create bucket at dash.cloudflare.com → R2 → Create bucket
R2_BUCKET=gotryl-artifacts
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# AI — Anthropic API key for test generation (Claude Sonnet 4.6) and
# root-cause classification (Claude Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# Internal service auth — shared secret for API ↔ Executor calls
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=generate-with-openssl-rand-hex-32

# GitHub App — required for PR comment integration (Story 7.2)
# Register at github.com/settings/apps → New GitHub App
# Permissions: Pull requests (read & write), Metadata (read)
# Webhook events: pull_request
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# Optional
LOG_LEVEL=info
