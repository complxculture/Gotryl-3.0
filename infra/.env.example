# Database (PostgreSQL 16) — Railway PostgreSQL addon provides this
DATABASE_URL=postgresql://user:password@host:5432/gotryl

# Redis — Railway Redis addon provides this
# Required for BullMQ run dispatch queue (Epic 2)
REDIS_URL=redis://default:password@host:6379

# Cloudflare R2 — Artifact storage for screenshots, videos, DOM snapshots
# Create bucket at dash.cloudflare.com → R2 → Create bucket
R2_BUCKET=gotryl-artifacts
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# AI — Anthropic API key for test generation (Claude Sonnet 4.6) and
# root-cause classification (Claude Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# Internal service auth — shared secret for API ↔ Executor calls (no JWT)
INTERNAL_SERVICE_SECRET=generate-a-long-random-string

# Optional
PORT=3001
LOG_LEVEL=info
